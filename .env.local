# ================================================================
# ENVIRONMENT VARIABLES — rename file ini menjadi .env.local
# ================================================================

# ── DATABASE MYSQL (satu database di hosting) ────────────────────
# Semua data store + tabel JPremium ada di database yang sama
# Ambil info ini dari cPanel → MySQL Databases
DB_HOST=localhost
DB_PORT=3306
DB_USER=namauser_dbmu
DB_PASSWORD=password_dbmu
DB_NAME=namadb_minecraft

# ── JWT SECRET ───────────────────────────────────────────────────
# Buat string random panjang (min 32 karakter), contoh:
# openssl rand -base64 32
JWT_SECRET=ganti-dengan-random-string-panjang-minimal-32-karakter

# ── MIDTRANS (QRIS Payment Gateway) ─────────────────────────────
# Daftar gratis di: https://dashboard.midtrans.com
# Gunakan key Sandbox dulu untuk testing
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
# Ganti ke "production" saat sudah live
MIDTRANS_ENV=sandbox

# ── URL WEBSITE ──────────────────────────────────────────────────
# Saat development:
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Saat production (ganti dengan domain asli):
# NEXT_PUBLIC_BASE_URL=https://store.servermu.com

# ── RCON (Minecraft Server) ───────────────────────────────────────
# Untuk auto-deliver item setelah pembayaran berhasil
# Pastikan enable-rcon=true di server.properties Minecraft kamu
RCON_HOST=ip.server.minecraft.kamu
RCON_PORT=25575
RCON_PASSWORD=password_rcon_di_server_properties

# ── ADMIN PANEL ───────────────────────────────────────────────────
# Kredensial login admin pertama kali (sebelum buat akun lewat DB)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=GantiPasswordIniSekarang!

# ── JPREMIUM — nama tabel ─────────────────────────────────────────
# Default tabel JPremium (biasanya tidak perlu diubah):
#   jpremium_players   → data player (uuid, name, premium status)
#   jpremium_accounts  → password player non-premium (bcrypt)
# Ubah hanya jika kamu custom table_prefix di config JPremium
JPREMIUM_PLAYERS_TABLE=jpremium_players
JPREMIUM_ACCOUNTS_TABLE=jpremium_accounts
